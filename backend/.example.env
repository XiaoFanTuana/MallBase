# ============================================================
# backend/.example.env —— ThinkPHP 运行时模板
# ============================================================
# 用途：ThinkPHP 运行时通过 env 函数读取的完整业务配置。
#      本文件是后端运行配置的模板：
#        1. Docker 开发模式：ensure-env 会自动派生 backend/.mallbase-env/backend.env
#        2. 非 Docker 模式：也可手动复制为 backend/.env 后按需修改
#
# Docker 开发模式下，请优先修改项目根目录 .env，而不是直接编辑派生文件。
# Docker compose 变量插值模板在 deploy/docker/.example.env；详见 docs/install/env-files.md。
# ============================================================

# -------- Compose 隔离（仅 docker compose 读取） --------
# 同一台服务器部署多套 MallBase 时使用；ThinkPHP 运行时不读取这两项。
MALLBASE_COMPOSE_PROJECT_NAME=mallbase
MALLBASE_CONTAINER_PREFIX=mallbase

# -------- 应用 --------
# 调试模式，生产必须设为 false
APP_DEBUG=true
# 是否开启定时任务
CRON_ENABLE=false
# 队列连接：单机可用 sync；多副本环境建议 redis，并单独运行 queue worker
QUEUE_CONNECTION=sync
# 是否启用 Swoole 内置队列 Worker；队列 worker 列表在 config/swoole.php 维护
SWOOLE_QUEUE_ENABLE=false
QUEUE_REDIS_QUEUE=default
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_SELECT=0
QUEUE_REDIS_TIMEOUT=0
QUEUE_REDIS_PERSISTENT=false
# 默认语言
DEFAULT_LANG=zh-cn

# -------- 数据库 --------
DB_TYPE=mysql
# 连接目标：compose MySQL 容器填 mysql；宿主 MySQL 填 host.docker.internal；本地直跑填 127.0.0.1
DB_HOST=mysql
# Docker 开发全套模式下由根 .env 同步
DB_NAME=mallbase
# Docker 开发全套模式下由根 .env 同步；不要使用 root
DB_USER=mallbase
# Docker 开发全套模式下由根 .env 同步
DB_PASS=please-change-or-leave-for-random
# ThinkPHP 连接 MySQL 的容器内端口固定为 3306，不是宿主暴露端口 MYSQL_PORT
DB_PORT=3306
DB_CHARSET=utf8mb4
DB_PREFIX=mb_

# -------- 缓存，默认 redis；本地无 redis 可改为 file --------
CACHE_DRIVER=redis
CACHE_PREFIX=
CACHE_EXPIRE=0
CACHE_TAG_PREFIX=tag:

# -------- Redis --------
# Redis 主机：compose Redis 容器填 redis；宿主 Redis 填 host.docker.internal；本地直跑填 127.0.0.1
REDIS_HOST=redis
# compose 部署必须保持 6379；本地直跑时改为宿主 Redis 的实际端口
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=0
REDIS_PERSISTENT=false
REDIS_CACHE_DB=0

# -------- JWT，Docker 开发全套模式首次派生时会自动生成随机值 --------
JWT_SECRET=please-change-or-leave-for-random
JWT_EXPIRE=7200
JWT_REFRESH_EXPIRE=2592000
# 安装流程写入；用于判断当前 Swoole 进程是否已加载最新运行配置。
# Docker 再次派生运行配置时必须保留该值。
INSTALL_RUNTIME_MARKER=

# -------- Swoole HTTP 与 Worker --------
SWOOLE_HTTP_HOST=0.0.0.0
# Docker 开发全套模式下由根 .env 同步
SWOOLE_HTTP_PORT=8080
# Docker 开发全套模式默认由根 .env 同步为 1，避免按 CPU 核数启动过多 worker
SWOOLE_WORKER_NUM=0
SWOOLE_MAX_REQUEST=2000
SWOOLE_MAX_CONN=0
SWOOLE_BACKLOG=0
SWOOLE_RELOAD_ASYNC=true
SWOOLE_MAX_WAIT_TIME=60
SWOOLE_HEARTBEAT_IDLE_TIME=120
SWOOLE_HEARTBEAT_CHECK_INTERVAL=60
SWOOLE_POOL_MAX_WAIT_TIME=5
SWOOLE_DB_POOL_MAX_ACTIVE=3
SWOOLE_CACHE_POOL_MAX_ACTIVE=3
SWOOLE_REDIS_POOL_MAX_ACTIVE=3

# -------- 站点域名 --------
# 运行期权威来源：mb_setting.site_url，安装时写入且后台可修改。
# SITE_URL 用于安装页默认值、install:auto 输入以及运维查看静态副本。
# Docker 开发全套模式下，此键会从根 .env 同步过来。
SITE_URL=

# -------- CORS --------
# 多个允许的前端 Origin 使用英文逗号分隔；留空表示只允许同源请求。
# 启用凭据时通配符 * 不生效，必须逐个填写可信 Origin。
CORS_ALLOWED_ORIGINS=http://localhost:5666,http://127.0.0.1:5666,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false

# -------- 平台实例统计 --------
# 私有 fork 建议保持 true；改为 false 后才会发送实例激活与低频心跳。
PLATFORM_REPORT_DISABLED=true
