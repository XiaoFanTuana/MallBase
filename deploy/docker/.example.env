# ============================================================
# deploy/docker/.example.env —— 项目根 .env 主配置模板
# ============================================================
# 用途：Docker 开发全套模式、Docker 生产模式和本地命令行安装时，用户优先维护项目根目录 .env 这一份主配置。
#      Docker 全套模式下，ensure-env 会根据本模板生成 / 补齐根 .env，
#      并继续派生 backend/.mallbase-env/backend.env。
#      Docker 生产模式下，docker-compose.yml 会通过 env_file 把根 .env 注入后端容器。
#      本地命令行安装时，php think install:auto 会自动读取项目根 .env。
#
# 使用方式（三选一）：
#   1. 开发零配置：docker compose up 时 ensure-env 容器自动生成根 .env，并派生开发运行配置。
#   2. 开发或生产自定义：cp deploy/docker/.example.env .env，按注释修改后再 docker compose up -d。
#   3. 开发不改：直接 docker compose up -d，走零配置路径。
#
# 根 .env 是主配置源。
#    backend/.mallbase-env/backend.env 会自动生成，请不要把它当成第二份手工配置入口。
# ============================================================

# -------- Compose 隔离 --------
# 同一台服务器部署多套 MallBase 时使用。
MALLBASE_COMPOSE_PROJECT_NAME=mallbase
MALLBASE_CONTAINER_PREFIX=mallbase
# 使用 Docker Hub 已发布镜像时填写完整镜像名；本地构建可保留默认值。
MALLBASE_BACKEND_IMAGE=xiaofantuan/mallbase-backend:latest
MALLBASE_WEB_IMAGE=xiaofantuan/mallbase-web:latest

# -------- Full stack Web entrypoint --------
# 首次安装前保持本机绑定；完成安装并配置 TLS / 防火墙后再按需改为 0.0.0.0。
MALLBASE_BIND_HOST=127.0.0.1
MALLBASE_HTTP_PORT=8080

# -------- 应用运行态 --------
# 生产环境必须保持 false。Docker 开发全套模式不会把本字段同步到开发运行配置。
APP_DEBUG=false
# 生产环境必须改为强随机值。留空或占位时，后端容器入口脚本会生成随机值。
JWT_SECRET=please-change-or-leave-for-random
JWT_EXPIRE=7200
JWT_REFRESH_EXPIRE=2592000

# -------- 后端暴露端口 --------
# backend 容器对外暴露的 HTTP 端口，同时也是 Swoole 在容器内监听的端口。
SWOOLE_HTTP_PORT=8080
# Docker 开发全套模式默认 worker 数，设为 1 避免按 CPU 核数启动过多 worker。
SWOOLE_WORKER_NUM=1
SWOOLE_MAX_CONN=0
SWOOLE_BACKLOG=0

# -------- MySQL 宿主映射 --------
# 宿主机暴露的 MySQL 端口；容器内 MySQL 固定监听 3306。
MYSQL_PORT=3306
# 数据库 root 密码仅在首次容器初始化时生效；占位值会由 ensure-env 随机化。
MYSQL_ROOT_PASSWORD=please-change-or-leave-for-random

# -------- Redis 宿主映射 --------
# 仅 Docker 开发全套模式使用；容器内 Redis 固定监听 6379。
REDIS_HOST_PORT=6379

# -------- 业务数据库 --------
# Docker 全套模式用 mysql；本地命令行安装改为 127.0.0.1。
DB_HOST=mysql
# Docker 全套模式容器内固定 3306；本地安装按实际 MySQL 端口填写。
DB_PORT=3306
DB_NAME=mallbase
# 业务数据库用户不要使用 root。
DB_USER=mallbase
# 占位值会由 ensure-env 随机化。
DB_PASS=please-change-or-leave-for-random

# -------- 业务 Redis --------
# Docker 全套模式用 redis；本地命令行安装改为 127.0.0.1。
REDIS_HOST=redis
# Docker 全套模式容器内固定 6379；本地安装按实际 Redis 端口填写。
REDIS_PORT=6379
REDIS_CACHE_DB=0
REDIS_PASSWORD=
CACHE_DRIVER=redis

# -------- 站点域名 --------
# 运行期权威来源：mb_setting.site_url（安装完成后写入数据库）。
# 根 .env 中的 SITE_URL 仅用于：
# - 安装页默认值 / CLI 无人值守安装 install:auto 的输入
# - 安装完成后会写回后端运行配置作为静态副本，便于运维查看
# Web 安装页留空时会自动读取当前 request 域名。
# CLI 安装（install:auto）要求 SITE_URL 必须有值。
SITE_URL=http://localhost:8080

# -------- CORS --------
# 多个允许的前端 Origin 使用英文逗号分隔；留空表示只允许同源请求。
# 启用凭据时通配符 * 不生效，必须逐个填写可信 Origin。
CORS_ALLOWED_ORIGINS=http://localhost:5666,http://127.0.0.1:5666,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false

# -------- 平台实例统计 --------
# 私有 fork 建议保持 true；改为 false 后才会发送实例激活与低频心跳。
PLATFORM_REPORT_DISABLED=true
