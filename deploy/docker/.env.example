# ==========================================
# MallBase Docker 环境变量
# 复制到项目根目录: cp deploy/docker/.env.example .env
# ==========================================

# --- 容器端口 ---
APP_PORT=8080

# --- MySQL ---
# Docker Desktop (Mac/Win): host.docker.internal
# Linux 宿主机: 172.17.0.1 或实际 IP
# 云数据库: 填写 RDS 地址
# 开发全套模式: mysql（容器名）
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=mallbase
DB_USER=mallbase
DB_PASS=mallbase123

# --- Redis ---
# 同上，填写宿主机或云 Redis 地址
# 开发全套模式: redis（容器名）
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0

# --- 应用 ---
APP_DEBUG=false
CRON_ENABLE=false

# --- JWT ---
# 安装向导会自动生成，此处为手动部署参考
JWT_SECRET=please-change-me-to-a-random-string
JWT_EXPIRE=7200
JWT_REFRESH_EXPIRE=2592000

# --- Swoole ---
SWOOLE_WORKER_NUM=0
SWOOLE_MAX_REQUEST=2000

# --- CORS ---
# 生产环境改为具体域名，如 https://mall.example.com
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With

# --- 开发环境专用（docker-compose.dev.yml）---
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=mallbase123
