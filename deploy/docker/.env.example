# ==========================================
# MallBase Docker 部署环境变量
# 复制到项目根目录: cp deploy/docker/.env.example .env
# ==========================================

# ---------- MySQL（外部服务） ----------
# Docker Desktop (Mac/Win): host.docker.internal
# Linux 宿主机: 172.17.0.1 或实际 IP
# 云数据库: 填写 RDS 地址
DB_HOST=host.docker.internal
DB_PORT=3306
DB_NAME=mallbase
DB_USER=mallbase
DB_PASS=mallbase123

# ---------- Redis（外部服务） ----------
# 同上，填写宿主机或云 Redis 地址
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=0

# ---------- Backend ----------
APP_DEBUG=false
CRON_ENABLE=false
BACKEND_PORT=8080
SWOOLE_WORKER_NUM=0

# ---------- JWT ----------
# 安装向导会自动生成，此处为手动部署参考
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRE=7200
JWT_REFRESH_EXPIRE=2592000

# ---------- Frontend ----------
FRONTEND_PORT=80
# 前端请求后端 API 的路径前缀（Nginx 会反代到 backend 容器）
VITE_GLOB_API_URL=/api

# ---------- CORS ----------
CORS_ALLOWED_ORIGINS=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Requested-With
